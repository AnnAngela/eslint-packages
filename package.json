{
  "name": "@annangela/eslint-package",
  "version": "1.0.0",
  "description": "AnnAngela's ESLint packages Monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
  "scripts": {
    "changeset": "changeset",
    "version": "changeset version && pnpm install --no-frozen-lockfile",
    "release": "pnpm run build && pnpm publish -r --provenance --access public --no-git-checks",
    "build": "pnpm --filter @annangela/eslint-plugin-prefer-reflect --filter @annangela/eslint-formatter-gha --filter @annangela/eslint-config run build",
    "lint": "pnpm run check:packages && pnpm --filter @annangela/eslint-plugin-prefer-reflect run build && pnpm -r --reporter append-only --aggregate-output run lint && eslint --exit-on-fatal-error --max-warnings 0 .",
    "lint:ci": "pnpm run check:packages && pnpm --filter @annangela/eslint-plugin-prefer-reflect --filter @annangela/eslint-formatter-gha run build && pnpm run lint:ci:run",
    "lint:ci:run": "pnpm -r --reporter append-only --aggregate-output run lint && eslint --exit-on-fatal-error -f ./packages/eslint-formatter-gha/dist/index.js --max-warnings 0 .",
    "test:coverage": "pnpm -r --reporter append-only --aggregate-output run test:coverage",
    "verify:ci": "pnpm run check:packages && pnpm run build && pnpm run lint:ci:run && pnpm run test:coverage",
    "verify": "pnpm run lint && pnpm --filter @annangela/eslint-formatter-gha --filter @annangela/eslint-config run build && pnpm run test:coverage",
    "lint:check": "pnpm run lint",
    "lint:check-ci": "pnpm run lint:ci",
    "lint:write": "eslint --fix .",
    "ci": "echo \"Already done :)\"",
    "sync:packages": "node scripts/sync-metadata.js",
    "check:packages": "node scripts/sync-metadata.js --check",
    "verify:packages": "pnpm run check:packages",
    "package": "pnpm run build"
  },
  "engines": {
    "node": "^22.21 || ^24.11"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AnnAngela/eslint-packages.git"
  },
  "author": "AnnAngela",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/AnnAngela/eslint-packages/issues"
  },
  "homepage": "https://github.com/AnnAngela/eslint-packages#readme",
  "dependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^10.4.1",
    "eslint-plugin-eslint-plugin": "^7.4.0",
    "eslint-plugin-n": "^18.0.1",
    "eslint-plugin-prefer-arrow-functions": "^3.9.1",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.6.0",
    "pkg-types": "^2.3.1",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@vitest/coverage-v8": "4.1.9",
    "vitest": "4.1.9"
  }
}
