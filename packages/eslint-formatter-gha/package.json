{
  "name": "@annangela/eslint-formatter-gha",
  "version": "6.0.0",
  "description": "A better ESLint formatter used in GitHub Actions",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "node scripts/build.js",
    "lint": "eslint --exit-on-fatal-error --max-warnings 0 ./src",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "package": "pnpm run build",
    "preversion": "pnpm run lint",
    "version": "pnpm run package"
  },
  "engines": {
    "node": "^22.21 || ^24.11"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AnnAngela/eslint-packages.git",
    "directory": "packages/eslint-formatter-gha"
  },
  "keywords": [
    "eslint",
    "eslint-formatter",
    "eslintformatter"
  ],
  "author": "AnnAngela",
  "license": "MIT",
  "peerDependencies": {
    "eslint": "^10.0.0"
  },
  "bugs": {
    "url": "https://github.com/AnnAngela/eslint-packages/issues"
  },
  "homepage": "https://github.com/AnnAngela/eslint-packages/tree/master/packages/eslint-formatter-gha#readme",
  "devDependencies": {
    "@actions/core": "^3.0.1",
    "@types/node": "^25.9.1",
    "@types/tmp": "^0.2.6",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "semver": "^7.8.1",
    "tmp": "^0.2.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
