{
  "name": "@annangela/eslint-config",
  "version": "13.0.0",
  "description": "ESLint config for AnnAngela's projects",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./tsconfig.node22.json": "./dist/tsconfigs/tsconfig.node22.json",
    "./tsconfig.node22.cjs.json": "./dist/tsconfigs/tsconfig.node22.cjs.json",
    "./tsconfig.node24.json": "./dist/tsconfigs/tsconfig.node24.json",
    "./tsconfig.node24.cjs.json": "./dist/tsconfigs/tsconfig.node24.cjs.json",
    "./tsconfig.browser.json": "./dist/tsconfigs/tsconfig.browser.json"
  },
  "files": [
    "./dist"
  ],
  "type": "module",
  "scripts": {
    "build": "node scripts/build.js",
    "lint": "eslint --exit-on-fatal-error --max-warnings 0 ./src",
    "test": "node --input-type=module -e \"const { configs } = await import('./src/index.js'); for (const key of ['base', 'node', 'typescript']) { if (!(key in configs)) { throw new Error('Missing config export: ' + key); } }\"",
    "package": "npm run build",
    "preversion": "npm run lint",
    "version": "npm run package"
  },
  "engines": {
    "node": "^22.21 || ^24.11"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AnnAngela/eslint-packages.git",
    "directory": "packages/eslint-config"
  },
  "keywords": [
    "eslint",
    "eslint-plugin",
    "eslintplugin"
  ],
  "author": "AnnAngela",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/AnnAngela/eslint-packages/issues"
  },
  "homepage": "https://github.com/AnnAngela/eslint-packages/tree/master/packages/eslint-config#readme",
  "peerDependencies": {
    "eslint": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "semver": "^7.8.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@annangela/eslint-plugin-prefer-reflect": "^6.0.0",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/js": "^9.39.4",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@stylistic/eslint-plugin-migrate": "^4.4.1",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint-plugin-eslint-plugin": "^7.3.3",
    "eslint-plugin-n": "^18.0.1",
    "eslint-plugin-prefer-arrow-functions": "^3.9.1",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.6.0"
  }
}
