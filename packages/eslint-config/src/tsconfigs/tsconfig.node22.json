{
    "$schema": "https://json.schemastore.org/tsconfig",
    "extends": "./tsconfig.base.json",
    "display": "Node 22",
    "_version": "22.0.0",
    "compilerOptions": {
        // Modules
        "module": "nodenext", // Node 22 - https://github.com/tsconfig/bases#centralized-recommendations-for-tsconfig-bases
        "moduleResolution": "Node16", // Node 22 - https://github.com/tsconfig/bases#centralized-recommendations-for-tsconfig-bases
        "resolveJsonModule": true,
        "resolvePackageJsonExports": true,
        // Language and Environment
        // lib 对照 @tsconfig/node22 (https://github.com/tsconfig/bases/blob/main/bases/node22.json)
        // ESNext.Error (error.cause) 和 ESNext.Promise (Promise.withResolvers)
        // 在 Node 22 中不可用，因此排除。
        "lib": [ // Node 22 - https://github.com/tsconfig/bases#centralized-recommendations-for-tsconfig-bases
            "es2024",
            "ESNext.Array",
            "ESNext.Collection",
            "ESNext.Iterator",
        ],
        "target": "ES2022", // Node 22 - https://github.com/tsconfig/bases#centralized-recommendations-for-tsconfig-bases
    },
}
