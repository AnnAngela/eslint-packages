{
  "name": "@annangela/eslint-plugin-prefer-reflect",
  "version": "6.0.0",
  "description": "Modern version of original \"prefer-reflect\" rules in eslint",
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin"
  ],
  "author": "AnnAngela",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AnnAngela/eslint-packages.git",
    "directory": "packages/eslint-plugin-prefer-reflect"
  },
  "bugs": {
    "url": "https://github.com/AnnAngela/eslint-packages/issues"
  },
  "homepage": "https://github.com/AnnAngela/eslint-packages/tree/master/packages/eslint-plugin-prefer-reflect#readme",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "./dist"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "lint": "eslint --exit-on-fatal-error --max-warnings 0 ./src ./tests",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "package": "pnpm run build",
    "preversion": "pnpm run lint",
    "version": "pnpm run package"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.1",
    "eslint-plugin-eslint-plugin": "^7.3.3",
    "eslint-plugin-node": "^11.1.0",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": "^22.21 || ^24.11"
  },
  "license": "MIT"
}
